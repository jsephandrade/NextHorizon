@inject IWebHostEnvironment WebHostEnvironment
@inject IConfiguration Configuration
@{
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString();
    var isStorefrontPage = string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase);
    var showDevMessagingLink = WebHostEnvironment.IsDevelopment() &&
        Configuration.GetValue("Features:EnableDevMessaging", false);
    var bodyClass = isStorefrontPage ? "app-shell storefront-shell" : "app-shell member-shell";
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@(ViewData["Title"] ?? ViewBag.Title ?? "MemberTracker") - MemberTracker</title>

    @if (isStorefrontPage)
    {
        <link href="~/css/style.css" rel="stylesheet" asp-append-version="true" />
    }
    <link href="~/css/Header.css" rel="stylesheet" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
</head>

<body class="@bodyClass">

    <header id="main-header">
        <div class="site-header-shell">
            <div class="header-content">
                <div class="logo">
                    <a href="/"><img src="~/images/logo.png" alt="NEXT HORIZON" class="header-logo-img"></a>
                </div>

                <form class="header-search-form" action="/Home/Shop" method="get" role="search">
                    <div class="header-search-wrap">
                        <svg class="header-search-icon" width="17" height="17" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="search" name="q" id="header-search-input" placeholder="Search products..."
                               autocomplete="off" class="header-search-input">
                    </div>
                </form>

                <div class="header-actions">
                    @if (showDevMessagingLink)
                    {
                        <a asp-controller="Member" asp-action="DevMessaging" class="dev-messaging-btn">Dev Messaging</a>
                    }

                    <a href="/Home/Cart" class="cart-btn" aria-label="Shopping Cart">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="9" cy="21" r="1"></circle>
                            <circle cx="20" cy="21" r="1"></circle>
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                        </svg>
                        <span id="cart-count">0</span>
                    </a>

                    <div class="notif-wrap" id="notif-wrap">
                        <button class="notif-btn" id="notif-btn" onclick="toggleNotifDropdown()"
                                aria-label="Notifications">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                            <span class="notif-dot" id="notif-dot"></span>
                        </button>
                        <div class="notif-dropdown" id="notif-dropdown">
                            <div class="notif-header">
                                <span>Notifications</span>
                                <button class="notif-clear-btn" onclick="clearNotifications()">Clear all</button>
                            </div>
                            <ul class="notif-list" id="notif-list">
                                <li class="notif-item unread">
                                    <div class="notif-icon notif-icon-order">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2">
                                            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"></path>
                                            <line x1="3" y1="6" x2="21" y2="6"></line>
                                            <path d="M16 10a4 4 0 01-8 0"></path>
                                        </svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">Your order has been confirmed!</p>
                                        <span class="notif-time">Just now</span>
                                    </div>
                                </li>
                                <li class="notif-item unread">
                                    <div class="notif-icon notif-icon-preorder">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2">
                                            <circle cx="12" cy="12" r="10"></circle>
                                            <polyline points="12 6 12 12 16 14"></polyline>
                                        </svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">Apex Carbon Racer 2026 pre-order opens March 2026.</p>
                                        <span class="notif-time">2 hours ago</span>
                                    </div>
                                </li>
                                <li class="notif-item">
                                    <div class="notif-icon notif-icon-promo">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2">
                                            <path
                                                d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z">
                                            </path>
                                            <line x1="7" y1="7" x2="7.01" y2="7"></line>
                                        </svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">New arrivals just dropped - check them out!</p>
                                        <span class="notif-time">1 day ago</span>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="profile-wrap" id="profile-wrap">
                        <button class="login-btn" id="profile-btn" type="button" onclick="toggleProfileDropdown()"
                                aria-label="Profile menu" aria-controls="profile-dropdown" aria-expanded="false">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </button>
                        <div class="profile-dropdown" id="profile-dropdown">
                            <a href="/Member/UploadActivity" class="profile-dropdown-link">Member Upload</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    @RenderBody()

    @await Html.PartialAsync("_Footer")

    <script src="~/js/Header.js" asp-append-version="true"></script>
    @if (isStorefrontPage)
    {
        <script src="~/js/app.js" asp-append-version="true"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
