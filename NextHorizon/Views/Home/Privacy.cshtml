@{
    ViewData["Title"] = "Privacy";
}

@section Styles {
<style>
    .privacy-page {
        max-width: 960px;
        margin: 0 auto;
        padding: 48px 24px 88px;
    }

    .privacy-hero {
        margin-bottom: 32px;
    }

    .privacy-eyebrow {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: #666;
        margin-bottom: 12px;
    }

    .privacy-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.05;
        margin-bottom: 12px;
    }

    .privacy-subtitle {
        max-width: 680px;
        font-size: 15px;
        color: #555;
        line-height: 1.7;
    }

    .privacy-grid {
        display: grid;
        grid-template-columns: minmax(0, 260px) minmax(0, 1fr);
        gap: 24px;
        align-items: start;
    }

    .privacy-summary,
    .privacy-section {
        border: 1px solid #e7e7e7;
        border-radius: 16px;
        background: #fff;
        padding: 24px;
    }

    .privacy-summary {
        position: sticky;
        top: 100px;
    }

    .privacy-summary h2,
    .privacy-section h2 {
        font-size: 14px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 14px;
    }

    .privacy-summary ul,
    .privacy-section ul {
        padding-left: 18px;
        color: #555;
        line-height: 1.7;
    }

    .privacy-summary li + li,
    .privacy-section li + li {
        margin-top: 8px;
    }

    .privacy-sections {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .privacy-section p {
        color: #555;
        line-height: 1.75;
        margin-bottom: 12px;
    }

    .privacy-contact {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 8px;
        font-weight: 600;
        text-decoration: none;
        color: #111;
    }

    @@media (max-width: 820px) {
        .privacy-grid {
            grid-template-columns: 1fr;
        }

        .privacy-summary {
            position: static;
        }

        .privacy-title {
            font-size: 32px;
        }
    }
</style>
}

<div class="privacy-page">
    <div class="privacy-hero">
        <span class="privacy-eyebrow">Privacy</span>
        <h1 class="privacy-title">Your data stays handled with intent.</h1>
        <p class="privacy-subtitle">
            This storefront demo uses in-memory shopping data for cart, wishlist, and orders. That means your test activity
            is kept only for the current application session and is cleared when the app restarts.
        </p>
    </div>

    <div class="privacy-grid">
        <aside class="privacy-summary">
            <h2>At a Glance</h2>
            <ul>
                <li>Cart, wishlist, and order data are stored in server memory for demo purposes.</li>
                <li>No live payment processing or third-party checkout is connected.</li>
                <li>Review submissions update the in-memory catalog and are not persisted across restarts.</li>
                <li>Questions about data handling can be sent through the contact page.</li>
            </ul>
        </aside>

        <div class="privacy-sections">
            <section class="privacy-section">
                <h2>What This Demo Stores</h2>
                <p>
                    The storefront currently keeps product, seller, review, cart, wishlist, purchase-status, and order data
                    in application memory. This supports page flows such as checkout, order confirmation, review submission,
                    and seller browsing without writing customer storefront data into the main database.
                </p>
                <p>
                    Submitted checkout details are used to create a temporary order record so the order pages can display a
                    complete confirmation and history flow.
                </p>
            </section>

            <section class="privacy-section">
                <h2>How Long It Lasts</h2>
                <p>
                    Session data lasts only as long as the running application instance. If the app is restarted, the cart,
                    wishlist, and newly created orders return to the seeded demo state.
                </p>
                <p>
                    This is intentional for the current implementation and should not be treated as production-grade storage.
                </p>
            </section>

            <section class="privacy-section">
                <h2>Contact</h2>
                <p>
                    If you want a record corrected or removed from the demo content, use the contact page so the issue can be
                    reviewed with the current session state in mind.
                </p>
                <a class="privacy-contact" href="/Home/Contact">Go to Contact</a>
            </section>
        </div>
    </div>
</div>
