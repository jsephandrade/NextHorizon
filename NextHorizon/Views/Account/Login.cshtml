@model NextHorizon.Models.LoginViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Seller Login - Next Horizon";
}

@section Styles {
<style>
    body {
        background: #f4f5f7;
    }

    /* Login page header should show logo only */
    #main-header .header-search-form,
    #main-header .header-actions {
        display: none !important;
    }

    #main-header .header-content {
        justify-content: flex-start;
    }

    .login-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }

    .login-card {
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.10);
        width: 100%;
        max-width: 460px;
        padding: 44px 40px 36px;
    }

    .login-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
        text-decoration: none;
    }

    .login-logo img {
        height: 38px;
        width: auto;
    }

    .login-logo span {
        font-size: 20px;
        font-weight: 800;
        color: #111111;
        letter-spacing: 0.3px;
    }

    .login-heading {
        font-size: 26px;
        font-weight: 800;
        color: #111111;
        margin: 0 0 4px;
    }

    .login-subtext {
        font-size: 14px;
        color: #777777;
        margin: 0 0 28px;
    }

    .login-badge {
        display: inline-block;
        background: #f0f0f0;
        color: #444;
        font-size: 12px;
        font-weight: 700;
        border-radius: 6px;
        padding: 3px 10px;
        margin-bottom: 18px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: #333333;
        margin-bottom: 6px;
    }

    .form-input {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid #d1d5db;
        border-radius: 8px;
        font-size: 14px;
        color: #1f2937;
        background: #fafafa;
        box-sizing: border-box;
        transition: border-color 0.15s;
        outline: none;
    }

    .form-input:focus {
        border-color: #111111;
        background: #ffffff;
    }

    .password-input-wrap {
        position: relative;
    }

    .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: #9ca3af;
        padding: 4px;
        font-size: 15px;
        line-height: 1;
    }

    .password-toggle:hover {
        color: #555;
    }

    .password-input-wrap .form-input {
        padding-right: 40px;
    }

    .auth-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
        font-size: 13px;
    }

    .remember-me {
        display: flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        font-weight: 600;
        color: #444;
    }

    .login-btn {
        width: 100%;
        padding: 12px;
        background: #111111;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .login-btn:hover {
        background: #333333;
    }

    .text-danger {
        color: #dc2626;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    .validation-summary-errors ul {
        margin: 0;
        padding-left: 18px;
    }

    .alert-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 10px 14px;
        margin-bottom: 18px;
        font-size: 13px;
        color: #b91c1c;
    }
</style>
}

<div class="login-wrapper">
    <div class="login-card">
        <a asp-controller="Account" asp-action="Login" class="login-logo">
            <img src="~/images/new-logo.png" alt="Next Horizon" />
            <span>Next Horizon</span>
        </a>

        <span class="login-badge">Seller Portal</span>

        <h1 class="login-heading">Welcome back</h1>
        <p class="login-subtext">Log in to your seller dashboard</p>

        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="alert-error"></div>
            }

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-input" placeholder="seller@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group password-field">
                <label asp-for="Password" class="form-label">Password</label>
                <div class="password-input-wrap">
                    <input asp-for="Password" id="loginPassword" class="form-input" placeholder="Enter your password" type="password" autocomplete="current-password" />
                    <button type="button" class="password-toggle" onclick="toggleLoginPassword()" aria-label="Toggle password visibility">
                        <i class="fas fa-eye" id="loginPasswordIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="auth-options">
                <label class="remember-me">
                    <input asp-for="RememberMe" type="checkbox" />
                    <span>Remember me</span>
                </label>
            </div>

            <button type="submit" class="login-btn">
                <i class="fas fa-sign-in-alt"></i>
                Log In
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function toggleLoginPassword() {
        const input = document.getElementById('loginPassword');
        const icon = document.getElementById('loginPasswordIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('fa-eye', 'fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('fa-eye-slash', 'fa-eye');
        }
    }
</script>
}
