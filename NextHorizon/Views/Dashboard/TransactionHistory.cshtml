@model NextHorizon.Models.TransactionHistoryViewModel

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles{
    <link rel="stylesheet" href="~/css/finance.css" />
    <link rel="stylesheet" href="~/css/transactionhistory.css" />
}

@{
    ViewData["Title"] = "Transaction History";
    ViewData["DashboardHeading"] = "Transaction History";
    ViewData["SellerName"] = Model.SellerName;
}

<!-- Page Actions (Back Button) -->
<div class="page-actions">
    <a class="link-btn" asp-controller="Dashboard" asp-action="Finance">
        <i class="fas fa-arrow-left"></i> Back to Finance
    </a>
</div>

<!-- Filter Section -->
<section class="section">
    <h3 class="section-title">Filter Transactions</h3>
    <div class="filter-container">
        <form method="get" asp-action="TransactionHistory" class="filter-form">
            <div class="filter-grid">
                <div class="filter-group">
                    <label for="type">Transaction Type</label>
                    <select name="type" id="type" class="filter-select">
                        <option value="">All Types</option>
                        <option value="Withdrawal" selected="@(Model.FilterType == "Withdrawal")">Withdrawal</option>
                        <option value="Order Payout" selected="@(Model.FilterType == "Order Payout")">Order Payout</option>
                        <option value="Refund" selected="@(Model.FilterType == "Refund")">Refund</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="status">Status</label>
                    <select name="status" id="status" class="filter-select">
                        <option value="">All Status</option>
                        <option value="Completed" selected="@(Model.FilterStatus == "Completed")">Completed</option>
                        <option value="Pending" selected="@(Model.FilterStatus == "Pending")">Pending</option>
                        <option value="Failed" selected="@(Model.FilterStatus == "Failed")">Failed</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="fromDate">From Date</label>
                    <input type="date" name="fromDate" id="fromDate" class="filter-input" 
                           value="@(Model.FilterFromDate?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="filter-group">
                    <label for="toDate">To Date</label>
                    <input type="date" name="toDate" id="toDate" class="filter-input" 
                           value="@(Model.FilterToDate?.ToString("yyyy-MM-dd"))" />
                </div>

                <div class="filter-group filter-actions">
                    <button type="submit" class="btn-filter">
                        <i class="fas fa-filter"></i> Apply Filters
                    </button>
                    <a href="@Url.Action("TransactionHistory")" class="btn-reset">
                        <i class="fas fa-undo"></i> Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</section>

<!-- Transactions Table -->
<section class="section">
    <div class="table-header">
        <h3 class="section-title">All Transactions</h3>
        <div class="table-info">
            Showing @Model.Transactions.Count of @Model.TotalCount transactions
        </div>
    </div>

    <div class="table-container">
        <table class="orders-table">
            <thead>
                <tr>
                    <th>Reference</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Method</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in Model.Transactions)
                {
                    <tr>
                        <td>@tx.ReferenceId</td>
                        <td>@tx.TransactionDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                        <td>
                            <span class="transaction-type">
                                @if (tx.Type.Contains("Withdrawal"))
                                {
                                    <i class="fas fa-arrow-up text-warning"></i>
                                }
                                else if (tx.Type.Contains("Payout"))
                                {
                                    <i class="fas fa-arrow-down text-success"></i>
                                }
                                else if (tx.Type.Contains("Refund"))
                                {
                                    <i class="fas fa-undo text-danger"></i>
                                }
                                else
                                {
                                    <i class="fas fa-exchange-alt"></i>
                                }
                                @tx.Type
                            </span>
                        </td>
                        <td>@tx.Method</td>
                        <td class="@(tx.Amount < 0 ? "amount-negative" : "amount-positive")">
                            @if (tx.Amount < 0)
                            {
                                <span>- &#8369;@Math.Abs(tx.Amount).ToString("N2")</span>
                            }
                            else
                            {
                                <span>+ &#8369;@tx.Amount.ToString("N2")</span>
                            }
                        </td>
                        <td>
                            <span class="badge status 
                                @(tx.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ? "pending" : 
                                  tx.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "complete" : 
                                  tx.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase) ? "failed" : "")">
                                @tx.Status
                            </span>
                        </td>
                        <td class="action-buttons">
                            <a asp-action="TransactionDetails" asp-route-id="@tx.ReferenceId" class="btn-view" title="View Details">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (tx.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase) && tx.Type.Contains("Withdrawal"))
                            {
                                <a asp-action="CancelWithdrawal" asp-route-id="@tx.ReferenceId" 
                                   class="btn-cancel" title="Cancel Withdrawal"
                                   onclick="return confirm('Are you sure you want to cancel this withdrawal request?')">
                                    <i class="fas fa-times"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Transactions.Any())
                {
                    <tr>
                        <td colspan="7" class="empty-state">
                            <i class="fas fa-receipt fa-3x mb-3"></i>
                            <h5>No transactions found</h5>
                            <p class="text-muted">Try adjusting your filters or check back later</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="pagination-container">
            <ul class="pagination">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { 
                            page = Model.CurrentPage - 1,
                            type = Model.FilterType,
                            status = Model.FilterStatus,
                            fromDate = Model.FilterFromDate?.ToString("yyyy-MM-dd"),
                            toDate = Model.FilterToDate?.ToString("yyyy-MM-dd")
                        })">
                            <i class="fas fa-chevron-left"></i> Previous
                        </a>
                    </li>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { 
                            page = i,
                            type = Model.FilterType,
                            status = Model.FilterStatus,
                            fromDate = Model.FilterFromDate?.ToString("yyyy-MM-dd"),
                            toDate = Model.FilterToDate?.ToString("yyyy-MM-dd")
                        })">@i</a>
                    </li>
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("TransactionHistory", new { 
                            page = Model.CurrentPage + 1,
                            type = Model.FilterType,
                            status = Model.FilterStatus,
                            fromDate = Model.FilterFromDate?.ToString("yyyy-MM-dd"),
                            toDate = Model.FilterToDate?.ToString("yyyy-MM-dd")
                        })">
                            Next <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                }
            </ul>
        </div>
    }
</section>