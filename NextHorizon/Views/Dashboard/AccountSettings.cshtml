@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Settings";
}

<link rel="stylesheet" href="~/css/accountsettings.css" />

<div class="settings-container">

    <div class="settings-header">
        <div>
            <h2>Account Settings</h2>
            <p>Manage your business profile and account details.</p>
        </div>
    </div>

    <div class="settings-card">

        <div class="settings-tabs">
            <button class="tab active" onclick="openTab(event,'profile')">Business Profile</button>
            <button class="tab" onclick="openTab(event,'account')">Account Details</button>
        </div>

        <!-- BUSINESS PROFILE -->
        <div id="profile" class="tab-content active">

            <div class="settings-grid">

                <div class="logo-section">

                    <div class="logo-box">
                        <img src="~/images/placeholder.png" id="logoPreview"/>
                    </div>

                    <input type="file" id="logoUpload" hidden />

                    <button class="upload-btn"
                            onclick="document.getElementById('logoUpload').click()">
                        Upload Logo
                    </button>

                </div>

                <div class="form-section">

                    <div class="form-group">
                        <label>Business Name</label>
                        <input type="text" value="Horizon Retail Hub"/>
                    </div>

                    <div class="form-group">
                        <label>Business Type</label>
                        <select>
                            <option>Sole Proprietor</option>
                            <option>Partnership</option>
                            <option>Corporation</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Business Email</label>
                        <input type="email" value="orders@horizonretail.ph"/>
                    </div>

                    <div class="form-group">
                        <label>Business Phone</label>
                        <input type="text" value="+63 917 555 1234"/>
                    </div>

                    <div class="form-group">
                        <label>Business Address</label>
                        <input type="text" placeholder="Address" />
                    </div>

                    <button class="apply-btn">Apply Changes</button>

                </div>

            </div>

        </div>

        <!-- ACCOUNT DETAILS TAB -->
        <div id="account" class="tab-content">

            <div class="form-section">

                <h3>Account Information</h3>

                <!-- Email Field -->
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" placeholder="Enter your email" disabled>
                </div>

                <!-- Separator -->
                <hr style="margin: 20px 0;">

                <!-- Inline Change Password Section -->
                <div class="password-section" style="border:1px solid #ccc; padding:20px; border-radius:8px; background:#f9f9f9;">

                    <h4 style="margin-bottom:15px;">Change Password</h4>

                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" placeholder="Enter current password" disabled>
                    </div>

                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" placeholder="Enter new password" disabled>
                    </div>

                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" placeholder="Confirm new password" disabled>
                    </div>

                </div>

                <!-- Edit / Save Button -->
                <div style="margin-top:15px; display:flex; justify-content:center;">
                    <button class="apply-btn" id="accountEditBtn">
                        Edit Account
                    </button>
                </div>

            </div>

        </div>

        <!-- UPDATE CONFIRMATION MODAL -->
        <div id="updateModal" class="modal-overlay">

            <div class="modal-box">

                <div class="modal-header">
                    <h3>Confirm Update</h3>
                    <span class="close-btn" onclick="closeAllModals()">&times;</span>
                </div>

                <div class="modal-body">
                    <p id="updateModalMessage">Are you sure you want to save these changes?</p>
                    <div style="display:flex; gap:10px; margin-top:20px; justify-content:center;">
                        <button class="apply-btn" id="confirmUpdateBtn">
                            Confirm
                        </button>
                        <button class="apply-btn" style="background:#ccc; color:black;" onclick="closeAllModals()">
                            Cancel
                        </button>
                    </div>
                </div>

            </div>

        </div>

        <!-- SUCCESS MODAL -->
        <div id="passwordChangedModal" class="modal-overlay">

            <div class="modal-box">

                <div class="modal-header">
                    <h3>Update Successful</h3>
                    <span class="close-btn" onclick="closeAllModals()">&times;</span>
                </div>

                <div class="modal-body">
                    <div style="text-align:center; margin-top:20px;">
                        <button class="apply-btn" onclick="closeAllModals()">OK</button>
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>

<!-- CHANGE PASSWORD MODAL -->
<div id="passwordModal" class="modal-overlay">

    <div class="modal-header">
        <h3>Change Password</h3>
        <span class="close-btn" onclick="closeAllModals()">&times;</span>
    </div>

    <div class="modal-box">


        <div class="modal-body">

            <div class="form-group">
                <label>Current Password</label>
                <input type="password" placeholder="Enter current password">
            </div>

            <div class="form-group">
                <label>New Password</label>
                <input type="password" placeholder="Enter new password">
            </div>

            <div class="form-group">
                <label>Confirm New Password</label>
                <input type="password" placeholder="Confirm new password">
            </div>

            <button class="apply-btn" onclick="openUpdateModal()">
                Update Password
            </button>

        </div>

    </div>

</div>

<!-- UPDATE PASSWORD CONFIRMATION MODAL -->
<div id="updateModal" class="modal-overlay">

    <div class="modal-box">

        <div class="modal-header">
            <h3>Confirm Update</h3>
            <span class="close-btn" onclick="closeAllModals()">&times;</span>
        </div>

        <div class="modal-body">

            <p>Are you sure you want to make this change?</p>

            <div style="display:flex; gap:10px; margin-top:20px; justify-content:center;">
                <button class="apply-btn" onclick="confirmPasswordUpdate()">
                    Confirm
                </button>

                <button class="apply-btn" style="background:#ccc; color:black;"
                        onclick="closeAllModals()">
                    Cancel
                </button>
            </div>

        </div>

    </div>

</div>

<!-- PASSWORD CHANGED SUCCESS MODAL -->
<div id="passwordChangedModal" class="modal-overlay">

    <div class="modal-box">

        <div class="modal-header">
            <h3>Password Changed Successfully</h3>
            <span class="close-btn" onclick="closeAllModals()">&times;</span>
        </div>

        <div class="modal-body">
            <div style="text-align:center; margin-top:20px;">
                <button class="apply-btn" onclick="closeAllModals()">OK</button>
            </div>
        </div>

    </div>

</div>

<script src="~/js/accountsettings.js"></script>

