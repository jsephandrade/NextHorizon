@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Settings";

    var userId = 0;
    
    // Safely check session
    if (Context?.Session != null)
    {
        userId = Context.Session.GetInt32("UserId") 
              ?? Context.Session.GetInt32("userId") 
              ?? 0;
    }

    // Safely check authentication (this fixes the CS8602 warning!)
    if (userId == 0 && User?.Identity?.IsAuthenticated == true)
    {
        var claimId = User.Claims.FirstOrDefault(c => c.Type == "UserId")?.Value;
        int.TryParse(claimId, out userId);
    }
}

<link rel="stylesheet" href="~/css/accountsettings.css" />

<input type="hidden" id="loggedInUserId" value="@userId" />

<div class="settings-container">

    <div class="settings-header">
        <div>
            <h2>Account Settings</h2>
            <p>Manage your business profile and account details.</p>
        </div>
    </div>

    <div class="settings-card">

        <div class="settings-tabs">
            <button class="tab active" onclick="openTab(event,'profile')">Business Profile</button>
            <button class="tab" onclick="openTab(event,'account')">Account Details</button>
        </div>

        <div id="profile" class="tab-content active">

            <div class="settings-grid">

                <div class="logo-section">
                    <div class="logo-box">
                        <img src="~/images/placeholder.png" id="logoPreview"/>
                    </div>
                    <input type="file" id="logoUpload" hidden />
                    <button class="upload-btn" onclick="document.getElementById('logoUpload').click()">
                        Upload Logo
                    </button>
                </div>

                <div class="form-section">

                    <div class="form-group">
                        <label>Business Name</label>
                        <input type="text" id="businessName" placeholder="Business Name"/>
                    </div>

                    <div class="form-group">
                        <label>Business Type</label>
                        <select id="businessType">
                            <option value="Sole Proprietor">Sole Proprietor</option>
                            <option value="Partnership">Partnership</option>
                            <option value="Corporation">Corporation</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Business Email</label>
                        <input type="email" id="businessEmail" placeholder="Business Email"/>
                    </div>

                    <div class="form-group">
                        <label>Business Phone</label>
                        <input type="text" id="businessPhone" placeholder="Business Phone"/>
                    </div>

                    <div class="form-group">
                        <label>Business Address</label>
                        <input type="text" id="businessAddress" placeholder="Business Address" />
                    </div>

                    <button class="apply-btn" onclick="openUpdateModal('Are you sure you want to save your Business Profile?')">Apply Changes</button>

                </div>

            </div>

        </div>

        <div id="account" class="tab-content">

            <div class="form-section">

                <h3>Account Information</h3>

              <div class="form-group">
    <label>Email Address</label>
    <div style="display: flex; gap: 10px; align-items: center;">
        <input type="email" id="displayEmail" placeholder="Fetching email..." style="flex-grow: 1;" disabled>
        <button type="button" class="apply-btn" style="width: auto; padding: 5px 15px;" onclick="openEmailChangeModal()">
            Change
        </button>
    </div>
</div>

                <hr style="margin: 20px 0;">

                <div class="password-section" style="border:1px solid #ccc; padding:20px; border-radius:8px; background:#f9f9f9;">
                    <h4 style="margin-bottom:15px;">Change Password</h4>

                    <div class="form-group">
                        <label>Current Password</label>
                        <input type="password" id="currentPassword" placeholder="Enter current password" disabled>
                    </div>

                    <div class="form-group">
                        <label>New Password</label>
                        <input type="password" id="newPassword" placeholder="Enter new password" disabled>
                    </div>

                    <div class="form-group">
                        <label>Confirm New Password</label>
                        <input type="password" id="confirmNewPassword" placeholder="Confirm new password" disabled>
                    </div>
                </div>

                <div style="margin-top:15px; display:flex; justify-content:center;">
                    <button class="apply-btn" id="accountEditBtn">
                        Edit Account
                    </button>
                </div>

            </div>

        </div>

        <div id="updateModal" class="modal-overlay">
            <div class="modal-box">
                <div class="modal-header">
                    <h3>Confirm Update</h3>
                    <span class="close-btn" onclick="closeAllModals()">&times;</span>
                </div>
                <div class="modal-body">
                    <p id="updateModalMessage">Are you sure you want to save these changes?</p>
                    <div style="display:flex; gap:10px; margin-top:20px; justify-content:center;">
                        <button class="apply-btn" id="confirmUpdateBtn">Confirm</button>
                        <button class="apply-btn" style="background:#ccc; color:black;" onclick="closeAllModals()">Cancel</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="passwordChangedModal" class="modal-overlay">
            <div class="modal-box">
                <div class="modal-header">
                    <h3>Update Successful</h3>
                    <span class="close-btn" onclick="closeAllModals()">&times;</span>
                </div>
                <div class="modal-body">
                    <div style="text-align:center; margin-top:20px;">
                        <button class="apply-btn" onclick="closeAllModals()">OK</button>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>
<div id="emailChangeModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Change Account Email</h3>
            <span class="close-btn" onclick="closeAllModals()">&times;</span>
        </div>
        <div class="modal-body">
            
            <div id="emailStep1">
                <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;">
                    Enter your new email and your current password to receive a verification code.
                </p>
                <div class="form-group">
                    <label>New Email Address</label>
                    <input type="email" id="newEmailInput" placeholder="example@newemail.com">
                </div>
                <div class="form-group">
                    <label>Current Password</label>
                    <input type="password" id="emailChangePassword" placeholder="Confirm your identity">
                </div>
                <button class="apply-btn" onclick="requestEmailOTP()">Send Verification Code</button>
            </div>

            <div id="emailStep2" style="display:none;">
                <p style="font-size: 0.9rem; color: #666; margin-bottom: 15px;">
                    We've sent a 6-digit code to <strong id="pendingEmailSpan" style="color:#000;"></strong>.
                </p>
                <div class="form-group">
                    <label>Enter 6-Digit OTP</label>
                    <input type="text" id="emailOTPInput" placeholder="· · · · · ·" maxlength="6" 
                           style="text-align: center; font-size: 1.8rem; letter-spacing: 8px; font-weight: bold; border: 2px solid #ddd;">
                </div>
                <button class="apply-btn" onclick="verifyEmailChange()">Verify & Update Email</button>
                <p style="text-align: center; margin-top: 15px;">
                    <span style="font-size: 0.85rem; color: #777;">Didn't get the code?</span><br>
                    <a href="#" onclick="requestEmailOTP()" style="color: #007bff; font-size: 0.85rem; text-decoration: none; font-weight: 600;">Resend Code</a>
                </p>
            </div>

        </div>
    </div>
</div>
<script src="~/js/accountsettings.js"></script>