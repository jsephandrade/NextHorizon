@model NextHorizon.Models.SellerDashboardViewModel
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles{
    <link rel="stylesheet" href="~/css/sellerdashboard.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Seller Dashboard";
    ViewData["DashboardHeading"] = "Dashboard";
    ViewData["SellerName"] = Model.SellerName;
}

<div class="greeting">
    <h1>Good Morning, @Model.SellerName!</h1>
    <p>@Model.CurrentDate.ToString("dddd, MMMM dd, yyyy")</p>
</div>

<section class="section">
    <h2 class="section-title">Critical Action</h2>
    <div class="cards-grid">
        <div class="card critical-card">
            <div class="card-content">
                <div class="card-info">
                    <span class="card-label">Orders to Ship (Urgent)</span>
                </div>
                <div class="card-badge urgent">@Model.OrdersToShip</div>
            </div>
        </div>

        <div class="card critical-card">
            <div class="card-content">
                <div class="card-info">
                    <span class="card-label">Pending Orders</span>
                </div>
                <div class="card-badge pending">@Model.PendingOrders</div>
            </div>
        </div>

        <div class="card critical-card">
            <div class="card-content">
                <div class="card-info">
                    <span class="card-label">Low Stock Alerts</span>
                </div>
                <div class="card-badge alert">@Model.LowStockAlerts</div>
            </div>
        </div>

    </div>
</section>

<div class="bottom-grid">
    <section class="section">
        <h2 class="section-title">Recent Orders</h2>
        <div class="table-container">
            <table class="orders-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Size</th>
                        <th>Customer</th>
                        <th>Time</th>
                        <th>Preferred Courier</th>
                        <th>Status</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.RecentOrders)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>
                                <div class="recent-product-cell">
                                    <img src="@order.ProductImage"
                                         alt="@order.ProductName"
                                         onerror="this.src='https://via.placeholder.com/60?text=Product'" />
                                    <div class="recent-product-meta">
                                        <div class="recent-product-name">@order.ProductName</div>
                                    </div>
                                </div>
                            </td>
                            <td>@order.Sku</td>
                            <td>@order.Size</td>
                            <td>@order.Customer</td>
                            <td>@order.DateTime.ToString("MMM dd, yyyy h:mm tt")</td>
                            <td>@order.Courier</td>
                            <td>
                                <span class="status-badge @order.Status.ToLower().Replace(" ", "-")">
                                    @order.Status
                                </span>
                            </td>
                            <td>&#8369;@order.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
