@model NextHorizon.Models.BalanceDetailsViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/mybalance.css" asp-append-version="true" />
}

<div class="page-actions">
    <a class="link-btn" asp-controller="Dashboard" asp-action="Finance">
        <i class="fas fa-arrow-left"></i> Back to Finance
    </a>
    <a class="link-btn" asp-controller="Dashboard" asp-action="Withdraw">
        <i class="fas fa-hand-holding-usd"></i> Withdraw Funds
    </a>
</div>

<div class="balance-page">

    <!-- Balance Header -->
    <div class="balance-box">
        <h2 class="balance-page-title">My Balance</h2>
        <p class="balance-description">
            Welcome back, <strong>@Model.SellerName</strong> • Last updated: @Model.CurrentDate.ToString("MMM dd, yyyy hh:mm tt")
        </p>
    </div>

    <!-- Balance Cards -->
    <section class="section">
        <div class="cards-grid performance-grid">
            
            <!-- Available Balance Card -->
            <div class="card performance-card clickable-card"
                 onclick="window.location.href='@Url.Action("Withdraw","Dashboard")'">
                <div class="card-header">
                    <span class="card-label">Available Balance</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.AvailableBalance.ToString("N2")</div>
                    <div class="metric-growth positive">
                        <i class="fas fa-check-circle"></i>
                        <span>Ready to withdraw</span>
                    </div>
                </div>
            </div>

            <!-- Pending Balance Card -->
            <div class="card performance-card clickable-card"
                 onclick="window.location.href='@Url.Action("TransactionHistory","Dashboard", new { status = "Pending" })'">
                <div class="card-header">
                    <span class="card-label">Pending Balance</span>
                    @if (Model.PendingPayoutCount > 0)
                    {
                        <span class="badge bg-warning">@Model.PendingPayoutCount</span>
                    }
                </div>
                <div class="card-body">
                    <div class="metric-value pending">&#8369;@Model.PendingBalance.ToString("N2")</div>
                    <div class="metric-growth">
                        <i class="fas fa-clock"></i>
                        <span>@Model.PendingPayoutCount pending request(s)</span>
                    </div>
                </div>
            </div>

            <!-- Total Withdrawn Card -->
            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Total Withdrawn</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.TotalWithdrawn.ToString("N2")</div>
                    <div class="metric-growth">
                        <i class="fas fa-money-bill-wave"></i>
                        <span>Completed payouts</span>
                    </div>
                </div>
            </div>

            <!-- Total Earned Card -->
            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Total Earned</span>
                </div>
                <div class="card-body">
                    <div class="metric-value positive">&#8369;@Model.TotalEarned.ToString("N2")</div>
                    <div class="metric-growth positive">
                        <i class="fas fa-chart-line"></i>
                        <span>Lifetime earnings</span>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Summary Cards -->
    <section class="section">
        <div class="cards-grid">
            <div class="card">
                <span class="card-label">Total Gross (All Time)</span>
                <div class="card-value">&#8369;@Model.TotalEarned.ToString("N2")</div>
                <small class="text-muted">Total earnings before withdrawals</small>
            </div>
            <div class="card">
                <span class="card-label">Pending Withdrawals</span>
                <div class="card-value">&#8369;@Model.TotalPendingWithdrawal.ToString("N2")</div>
                <small class="text-muted"> transaction(s) pending</small>
            </div>
            <div class="card">
                <span class="card-label">Net Balance</span>
                <div class="card-value">&#8369;@((Model.AvailableBalance + Model.PendingBalance).ToString("N2"))</div>
                <small class="text-muted">Available + Pending</small>
            </div>
        </div>
    </section>

    <!-- Recent Transactions -->
    <section class="section">
        <div class="transaction-header">
            <h3 class="finance-section-title">Recent Transactions</h3>
            <div class="page-actions">
                <a class="link-btn" asp-controller="Dashboard" asp-action="TransactionHistory">
                    <i class="fas fa-list"></i> View All Transactions
                </a>
            </div>
        </div>
        
        <div class="table-container">
            @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
            {
                <table class="orders-table">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Method</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model.RecentTransactions)
                        {
                            <tr>
                                <td>@tx.ReferenceId</td>
                                <td>@tx.TransactionDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                <td>
                                    <span class="transaction-type">
                                        @if (tx.Type.Contains("Withdrawal"))
                                        {
                                            <i class="fas fa-arrow-up text-warning"></i>
                                        }
                                        else if (tx.Type.Contains("Payout"))
                                        {
                                            <i class="fas fa-arrow-down text-success"></i>
                                        }
                                        else if (tx.Type.Contains("Refund"))
                                        {
                                            <i class="fas fa-undo text-danger"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-exchange-alt"></i>
                                        }
                                        @tx.Type
                                    </span>
                                </td>
                                <td>@tx.Method</td>
                                <td class="@(tx.Amount < 0 ? "text-danger" : "text-success")">
                                    @if (tx.Amount < 0)
                                    {
                                        <span>- &#8369;@Math.Abs(tx.Amount).ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>+ &#8369;@tx.Amount.ToString("N2")</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge status @(tx.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase) ? "pending" : 
                                                            tx.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) ? "complete" : 
                                                            tx.Status.Equals("Failed", StringComparison.OrdinalIgnoreCase) ? "failed" : "")">
                                        @tx.Status
                                    </span>
                                </td>
                                <td>
                                    <a asp-action="TransactionDetails" asp-route-id="@tx.ReferenceId" class="btn-view">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-exchange-alt fa-3x mb-3" style="color: #ccc;"></i>
                    <h4>No recent transactions</h4>
                    <p class="text-muted">Your recent transactions will appear here</p>
                    <a class="btn-filter mt-3" asp-controller="Dashboard" asp-action="TransactionHistory">
                        <i class="fas fa-list"></i> Go to Transaction History
                    </a>
                </div>
            }
        </div>
    </section>

</div>
