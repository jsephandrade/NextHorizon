@model FinanceViewModel
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<style>
    /* Hide sidebar for this page */
.sidebar {
    display: none !important;
}

/* Remove space left by sidebar */
.main-content {
    margin-left: 0 !important;
}

/* General Page Styling */
body {
    font-family: 'Inter', sans-serif;
    background: #f9f9f9;
    color: #1a1a1a;
    margin: 0;
}

.page-actions {
    margin-bottom: 24px;
    display: flex;
    gap: 12px;
}

/* Minimalist Back Button */
.link-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #1a1a1a;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
    border: none;
    padding: 0;
    transition: color 0.2s ease;
}

.link-btn i {
    font-size: 14px;
}

.link-btn:hover {
    color: white; /* subtle accent on hover */
}

/* Balance Page */
.balance-page {
    padding: 30px 20px;
}

/* Balance Box */
.balance-box {
    background: #fff;
    border-radius: 16px;
    padding: 40px 30px;
    max-width: 750px;
    margin: 0 auto 40px auto;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    text-align: center;
}

.balance-page-title {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
}

.balance-description {
    font-size: 15px;
    color: #4b4b4b;
}

/* Cards Grid */
.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.card {
    background: #fff;
    border-radius: 16px;
    padding: 25px 20px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    transition: all 0.3s ease;
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.card-label {
    font-size: 14px;
    font-weight: 600;
    color: #7a7a7a;
}

.metric-value {
    font-size: 32px;
    font-weight: 700;
    color: #1a1a1a;
    margin: 12px 0;
}

.metric-growth {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #7a7a7a;
}

.metric-growth.positive {
    color: #1a1a1a;
}

/* Transaction Table */
.table-container {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 8px 25px rgba(0,0,0,0.05);
}

.total-gross h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 15px;
    color: #1a1a1a;
}

/* Tabs */
.balance-tabs {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.balance-tabs .tab {
    padding: 8px 16px;
    border-radius: 50px;
    border: 1px solid #1a1a1a;
    background: #fff;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    color: #1a1a1a;
}

.balance-tabs .tab.active,
.balance-tabs .tab:hover {
    background: #1a1a1a;
    color: #fff;
    border-color: #1a1a1a;
}

/* Order Table */
.order-table {
    width: 100%;
    border-collapse: collapse;
    border-radius: 12px;
    overflow: hidden;
}

.order-table th,
.order-table td {
    padding: 14px 16px;
    text-align: left;
    color: #1a1a1a;
}

.order-table th {
    background: #f1f1f1;
    font-weight: 600;
    font-size: 13px;
}

.order-table tr:nth-child(even) {
    background: #fafafa;
}

.order-table tr:hover {
    background: #e0e0e0;
}
</style>
@{
    ViewData["Title"] = "My Balance";
}

<div class="page-actions">
    <a class="link-btn" asp-controller="Dashboard" asp-action="Finance">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>

<div class="balance-page">

    <!-- Balance Box -->
    <div class="balance-box">
        <h2 class="balance-page-title">My Balance</h2>
        <p class="balance-description">
            Check your available and pending balance
        </p>
    </div>

    <!-- Balance Cards -->
    <section class="section">
        <div class="cards-grid performance-grid">
            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Available Balance</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.AvailableBalance.ToString("N2")</div>
                    <div class="metric-growth positive">
                        <i class="fas fa-wallet"></i>
                        <span>Ready to withdraw</span>
                    </div>
                </div>
            </div>

            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Pending Payout</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.PendingPayout.ToString("N2")</div>
                    <div class="metric-growth">
                        <i class="fas fa-clock"></i>
                        <span>Under review</span>
                    </div>
                </div>
            </div>

            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Total Withdrawn</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.TotalWithdrawn.ToString("N2")</div>
                    <div class="metric-growth">
                        <i class="fas fa-money-bill-wave"></i>
                        <span>Completed payouts</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Transaction Table Section -->
    <section class="section">
        <div class="table-container">
            
            <!-- Total Gross -->
            <div class="total-gross">
                <h3>Total Gross: &#8369;@(Model.AvailableBalance + Model.PendingPayout + Model.TotalWithdrawn).ToString("N2")</h3>
            </div>

            <!-- Tabs -->
            <div class="balance-tabs">
                <button class="tab active">All</button>
                <button class="tab">Balance Records</button>
                <button class="tab">Earnings</button>
                <button class="tab">Adjustments</button>
                <button class="tab">Holds</button>
            </div>

            <!-- Transaction Table -->
            <table class="order-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Change</th>
                        <th>Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var txn in Model.Transactions)
                    {
                        <tr>
                            <td>@txn.TransactionDate.ToString("MM/dd/yyyy")</td>
                            <td>@txn.Type - @txn.Method</td>
                            <td>
                                @(txn.Amount >= 0 ? "+" : "-")&#8369;@Math.Abs(txn.Amount).ToString("N2")
                            </td>
                            <td><!-- You can calculate running balance here if needed --></td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </section>

</div>