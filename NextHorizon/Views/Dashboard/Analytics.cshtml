@using System.Linq
@using System.Text.Json
@using System.Globalization
@model NextHorizon.Models.SellerDashboardViewModel
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@{
    ViewData["Title"] = "Analytics";
    ViewData["DashboardHeading"] = "Analytics";
    ViewData["SellerName"] = Model.SellerName;

    var topProducts = Model.TopProducts.Take(5).ToList();
    var totalUnits = Math.Max(topProducts.Sum(p => p.UnitsSold), 1);
    var totalUnitSold = topProducts.Sum(p => p.UnitsSold);

    var first = topProducts.Count > 0 ? topProducts[0].UnitsSold : 0;
    var second = topProducts.Count > 1 ? topProducts[1].UnitsSold : 0;
    var third = topProducts.Count > 2 ? topProducts[2].UnitsSold : 0;
    var fourth = topProducts.Count > 3 ? topProducts[3].UnitsSold : 0;
    var fifth = topProducts.Count > 4 ? topProducts[4].UnitsSold : 0;

    var p1 = first * 100m / totalUnits;
    var p2 = second * 100m / totalUnits;
    var p3 = third * 100m / totalUnits;
    var p4 = fourth * 100m / totalUnits;
    var p5 = fifth * 100m / totalUnits;

    var s1 = 0m;
    var e1 = p1;
    var s2 = e1;
    var e2 = s2 + p2;
    var s3 = e2;
    var e3 = s3 + p3;
    var s4 = e3;
    var e4 = s4 + p4;
    var s5 = e4;
    var e5 = 100m;

    var donutGradient = $"conic-gradient(#5f6269 {s1:0.##}% {e1:0.##}%, #767a81 {s2:0.##}% {e2:0.##}%, #8a8f97 {s3:0.##}% {e3:0.##}%, #a5aab2 {s4:0.##}% {e4:0.##}%, #c5c9cf {s5:0.##}% {e5:0.##}%)";
    var donutPercentages = new List<decimal> { p1, p2, p3, p4, p5 };
    var donutLabels = new List<(string Left, string Top, string Text, bool DarkText)>();
    var cumulativePercent = 0m;
    const double labelRadiusPercent = 37.0;

    for (var i = 0; i < donutPercentages.Count; i++)
    {
        var segment = donutPercentages[i];
        if (segment <= 0)
        {
            continue;
        }

        var midPercent = cumulativePercent + (segment / 2m);
        var angle = (double)(midPercent * 3.6m) * (Math.PI / 180d);
        var left = 50d + (labelRadiusPercent * Math.Sin(angle));
        var top = 50d - (labelRadiusPercent * Math.Cos(angle));

        donutLabels.Add(
            (
                left.ToString("0.##", CultureInfo.InvariantCulture),
                top.ToString("0.##", CultureInfo.InvariantCulture),
                $"{segment:0.##}%",
                i >= 3
            )
        );

        cumulativePercent += segment;
    }

    var monthLabels = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    var viewedWeights = new decimal[] { 4.2m, 7.6m, 5.1m, 8.3m, 6.7m };
    var viewedScores = topProducts
        .Select((product, index) => product.UnitsSold * viewedWeights[Math.Min(index, viewedWeights.Length - 1)])
        .ToList();
    var maxViewedScore = viewedScores.Count > 0 ? viewedScores.Max() : 1m;
    var viewedBarHeights = viewedScores
        .Select(score => Math.Max(24m, decimal.Round((score / maxViewedScore) * 100m, 0)))
        .ToList();

    var monthlyRevenueByYear = Model.MonthlyRevenueByYear
        .Where(entry => entry.Value is { Count: > 0 })
        .OrderByDescending(entry => entry.Key)
        .ToList();
    var revenueDataJson = JsonSerializer.Serialize(
        monthlyRevenueByYear.ToDictionary(entry => entry.Key.ToString(), entry => entry.Value));
    var topProductsJson = JsonSerializer.Serialize(
        topProducts.Select(product => new
        {
            productName = product.ProductName,
            imageUrl = product.ImageUrl,
            sku = product.Sku,
            category = product.Category,
            unitsSold = product.UnitsSold,
            revenueGenerated = product.RevenueGenerated
        }));
    var topProductsByRangeJson = JsonSerializer.Serialize(
        Model.TopProductsByRange.ToDictionary(
            kvp => kvp.Key,
            kvp => kvp.Value.Select(p => new
            {
                productName = p.ProductName,
                imageUrl = p.ImageUrl,
                sku = p.Sku,
                category = p.Category,
                unitsSold = p.UnitsSold,
                revenueGenerated = p.RevenueGenerated
            }).ToList()));
}

@section Styles {
    <link rel="stylesheet" href="~/css/analytics.css" asp-append-version="true" />
}

<section class="analytics-page">

    <div class="analytics-welcome">
        <h2>Welcome<br />@Model.SellerName!</h2>
    </div>

    <section class="section">
        <h2 class="analytics-section-title">Performance</h2>
        <div class="cards-grid performance-grid">
            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Today's Sales</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.TodaySales.ToString("N2")</div>
                    <div class="metric-growth positive">
                        <i class="fas fa-arrow-up"></i>
                        <span>(+@Model.SalesGrowth%)</span>
                    </div>
                </div>
                <div class="card-chart">
                    <i class="fas fa-chart-line"></i>
                </div>
            </div>

            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Total Revenue</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">&#8369;@Model.TotalRevenue.ToString("N2")</div>
                </div>
            </div>

            <div class="card performance-card">
                <div class="card-header">
                    <span class="card-label">Total Unit Sold</span>
                </div>
                <div class="card-body">
                    <div class="metric-value">@totalUnitSold</div>
                </div>
            </div>
        </div>
    </section>

    <section class="analytics-panel revenue-panel">
        <div class="revenue-panel-header">
            <div>
                <h3 class="revenue-heading">Total Revenue Per Month</h3>
                <p class="revenue-subtext">Monthly revenue trend overview by selected year.</p>
            </div>
            <div class="revenue-year-filter">
                <label for="revenueYearSelect">Year</label>
                <select id="revenueYearSelect" class="revenue-year-select" aria-label="Revenue year selector">
                    @foreach (var yearlyRevenue in monthlyRevenueByYear)
                    {
                        <option value="@yearlyRevenue.Key">@yearlyRevenue.Key</option>
                    }
                </select>
            </div>
        </div>

        <div class="revenue-chart-shell" data-chart-data='@revenueDataJson'>
            <svg id="revenueLineGraph" class="revenue-chart-svg" viewBox="0 0 1080 320" role="img" aria-label="Total monthly revenue line graph">
                <g id="revenueGridLines"></g>
                <path id="revenueAreaPath" class="revenue-area"></path>
                <path id="revenueLinePath" class="revenue-line"></path>
                <g id="revenuePointGroup"></g>
                <g id="revenueLabelsGroup"></g>
            </svg>
            <div class="revenue-months" aria-hidden="true">
                @foreach (var month in monthLabels)
                {
                    <span>@month</span>
                }
            </div>
        </div>
    </section>

    <section class="analytics-panel">
        <div class="analytics-panel-header">
            <h3>Top Performing Products</h3>
            <div class="analytics-range-toggle" role="group" aria-label="Analytics date range">
                <button type="button" class="active" data-range="1H">1H</button>
                <button type="button" data-range="1D">1D</button>
                <button type="button" data-range="7D">7D</button>
                <button type="button" data-range="1M">1M</button>
            </div>
        </div>

        <div class="analytics-table-wrap" data-products='@topProductsJson' data-products-by-range='@topProductsByRangeJson'>
            <table class="analytics-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Product Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Unit Sold</th>
                        <th>Revenue Generated</th>
                    </tr>
                </thead>
                <tbody data-analytics-products>
                    @if (topProducts.Count == 0)
                    {
                        <tr class="analytics-empty-row">
                            <td colspan="6">
                                <div class="analytics-empty-state">
                                    <i class="fas fa-box-open"></i>
                                    <p>No product sales data found for your store yet.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var product in topProducts)
                        {
                            <tr>
                                <td>@product.Rank</td>
                                <td>
                                    <div class="analytics-product-cell">
                                        <img src="@product.ImageUrl" alt="@product.ProductName" onerror="this.src='https://via.placeholder.com/60?text=Product'" />
                                        <span>@product.ProductName</span>
                                    </div>
                                </td>
                                <td>@product.Sku</td>
                                <td>@product.Category</td>
                                <td>@product.UnitsSold</td>
                                <td>&#8369;@product.RevenueGenerated.ToString("N0")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="analytics-pagination" aria-label="Analytics table pages">
            <button type="button" class="analytics-page-btn active" data-page="1" aria-label="Page 1">1</button>
            <button type="button" class="analytics-page-btn" data-page="2" aria-label="Page 2">2</button>
            <button type="button" class="analytics-page-btn" data-page="3" aria-label="Page 3">3</button>
            <button type="button" class="analytics-page-btn" data-page="4" aria-label="Page 4">4</button>
            <button type="button" class="analytics-next-btn" id="analyticsNextPage" aria-label="Next page">Next</button>
        </div>
    </section>

</section>

@section Scripts {
<script src="~/js/analytics.js" asp-append-version="true"></script>
}

