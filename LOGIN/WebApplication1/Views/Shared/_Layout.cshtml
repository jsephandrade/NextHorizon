<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Join the ultimate runners community. Track your progress, compete on leaderboards, and connect with fellow runners.">
    <title>@ViewData["Title"] - Next Horizon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
      crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/styles.css">
    <link rel="stylesheet" href="~/css/loading.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

</head>
<body>
    <!-- Loading Screen - Valorant Inspired -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-logo">
            <div class="loading-circle"></div>
            <i class="fas fa-running loading-icon"></i>
        </div>
        <div class="loading-text">Next Horizon</div>
        <div class="loading-bar-container">
            <div class="loading-bar"></div>
        </div>
        <div class="loading-tagline">Sprint into the future</div>
    </div>

    <!-- Navigation -->
    <nav class="navbar" id="navbar">
        <!-- logo-edge sits at the viewport edge; main nav content stays centered in the container -->
        <a asp-controller="Home" asp-action="Index" class="logo logo-edge">
            <img src="~/images/Next Horizon Logo.png" alt="Next Horizon" class="logo-image">
            <span class="logo-text">Next Horizon</span>
        </a>

        <div class="navbar-container">
            <ul class="nav-links" id="navLinks">
            </ul>
        </div>

        <!-- actions-edge placed at viewport right edge -->
        <div class="nav-actions nav-actions-edge">
            <form class="search-form me-3">
                <input class="search-input" type="search" placeholder="Search products..." aria-label="Search">
                <button class="search-btn" type="submit"><i class="fas fa-search"></i></button>
            </form>
            <a asp-controller="Account" asp-action="Login" class="btn btn-secondary btn-sm">Log In</a>
            <a asp-controller="Account" asp-action="register" class="btn btn-primary btn-sm">Sign Up</a>
            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <i class="fas fa-bars"></i>
            </button>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-container">
            <div class="footer-top">
                <div class="footer-column">
                    <h4>Quick Links</h4>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="Products">Products</a></li>
                        <li><a asp-controller="Home" asp-action="Leaderboard">Leaderboard</a></li>
                        <li><a asp-controller="Account" asp-action="BecomeSeller">Become a Seller</a></li>
                    </ul>
                </div>
                
                <div class="footer-column">
                    <h4>Account</h4>
                    <ul class="footer-links">
                        <li><a asp-controller="Account" asp-action="Login">Log in</a></li>
                        <li><a asp-controller="Account" asp-action="Register">Sign Up</a></li>
                        <li><a asp-controller="Account" asp-action="ForgotPassword">Forgot Password</a></li>
                    </ul>
                </div>
                
                <div class="footer-column">
                    <h4>Legal</h4>
                    <ul class="footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a asp-controller="Home" asp-action="Terms">Terms of Service</a></li>
                        <li><a href="#">Cookie Policy</a></li>
                    </ul>
                </div>

                <div class="footer-brand">
                    <a asp-controller="Home" asp-action="Index" class="logo">
                        <img src="~/images/Next Horizon Logo.png" alt="Next Horizon" class="logo-image">
                        <span class="logo-text">Next Horizon</span>
                    </a>
                    <p>Connecting runners worldwide. Track, compete, and achieve your fitness goals together.</p>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2024 Next Horizon. All rights reserved.</p>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
        crossorigin="anonymous"></script>
    <!-- Bootstrap JS must load BEFORE custom scripts that use it -->
    <script src="~/js/loading.js"></script>
    <script src="~/js/main.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
