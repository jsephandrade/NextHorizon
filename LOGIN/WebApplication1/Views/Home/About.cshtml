@{
    ViewData["Title"] = "About Us";
}

<!-- About Hero Section -->
<section class="section" style="padding-top: 120px; background: var(--color-off-white);">
    <div class="about-container">
        <div class="about-image">
            <img src="~/images/about-runners.jpg" alt="Marathon runners">
        </div>
        
        <div class="about-content">
            <span class="section-label">About Us</span>
            <h3>Your Journey, Our Community</h3>
            <p>
                Next Horizon is more than just a tracking app - it's a thriving community of passionate 
                runners who motivate and inspire each other to reach new heights. Whether you're a 
                beginner or a seasoned marathoner, you'll find your place here.
            </p>
            <p>
                Our platform combines cutting-edge tracking technology with social features that 
                make every run more engaging and rewarding.
            </p>
            
            <div class="about-features">
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Track Progress</h4>
                        <p>Monitor your runs with detailed analytics</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-trophy"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Compete</h4>
                        <p>Climb the leaderboard rankings</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Connect</h4>
                        <p>Meet runners in your area</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <i class="fas fa-medal"></i>
                    </div>
                    <div class="feature-text">
                        <h4>Achieve</h4>
                        <p>Earn badges for milestones</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="section" style="background: var(--color-white);">
    <div class="contact-container" style="max-width: 1000px;">
        <div class="section-header" style="margin-bottom: 3rem;">
            <span class="section-label">Our Mission</span>
            <h2 class="section-title">Empowering Runners Worldwide</h2>
            <p class="section-description">
                We believe everyone has the potential to be a runner. Our mission is to provide the tools, 
                community, and motivation to help you achieve your running goals.
            </p>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; text-align: center;">
            <div style="padding: 2rem;">
                <div style="width: 80px; height: 80px; background: var(--color-black); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <i class="fas fa-bullseye" style="font-size: 2rem; color: var(--color-white);"></i>
                </div>
                <h4 style="margin-bottom: 1rem;">Our Vision</h4>
                <p style="color: var(--color-gray);">To become the global hub for runners, connecting athletes of all levels.</p>
            </div>
            
            <div style="padding: 2rem;">
                <div style="width: 80px; height: 80px; background: var(--color-black); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <i class="fas fa-heart" style="font-size: 2rem; color: var(--color-white);"></i>
                </div>
                <h4 style="margin-bottom: 1rem;">Our Values</h4>
                <p style="color: var(--color-gray);">Community, determination, and supporting every runner's journey.</p>
            </div>
            
            <div style="padding: 2rem;">
                <div style="width: 80px; height: 80px; background: var(--color-black); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                    <i class="fas fa-rocket" style="font-size: 2rem; color: var(--color-white);"></i>
                </div>
                <h4 style="margin-bottom: 1rem;">Our Goal</h4>
                <p style="color: var(--color-gray);">To make running accessible, enjoyable, and rewarding for everyone.</p>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="section" style="background: var(--color-black); color: var(--color-white);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem;">
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center;">
            <div>
                <h3 style="color: var(--color-white); font-size: 3rem; margin-bottom: 0.5rem;">50K+</h3>
                <p style="color: var(--color-gray);">Active Runners</p>
            </div>
            <div>
                <h3 style="color: var(--color-white); font-size: 3rem; margin-bottom: 0.5rem;">2M+</h3>
                <p style="color: var(--color-gray);">Miles Tracked</p>
            </div>
            <div>
                <h3 style="color: var(--color-white); font-size: 3rem; margin-bottom: 0.5rem;">500+</h3>
                <p style="color: var(--color-gray);">Sellers</p>
            </div>
            <div>
                <h3 style="color: var(--color-white); font-size: 3rem; margin-bottom: 0.5rem;">100+</h3>
                <p style="color: var(--color-gray);">Running Events</p>
            </div>
        </div>
    </div>
</section>
