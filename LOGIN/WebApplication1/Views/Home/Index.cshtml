                    <div class="text-center p-4 text-muted small">No records found.</div>
                }
            </div>

            @if (Model.ShowLoginWall)
            {
                    <div class="leaderboard-login-footer">
                        <a asp-controller="Account" asp-action="Login" class="btn-view-more">LOGIN TO SEE MORE</a>
                    </div>
            }
        </div>
        *@
       

            <!-- Bottom Sidebar Card: Static Promo or Ad -->
