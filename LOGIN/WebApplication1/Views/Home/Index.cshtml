        var myCarousel = document.querySelector('#promotionsCarousel');
        {
            var carouselInstance = new bootstrap.Carousel(myCarousel, {
                interval: 3000,
                pause: 'hover',
                wrap: true
            });
            console.log("Carousel initialized successfully.");
        }
    });
</script>
}

