                <img src="https://placehold.co/300x200/ff4655/fff?text=Flash+Sale" alt="Sidebar Promo">
                <div class="sidebar-overlay" style="position: absolute; bottom: 10px; left: 10px; color: white; font-weight: bold; text-shadow: 1px 1px 3px rgba(0,0,0,0.5);">
