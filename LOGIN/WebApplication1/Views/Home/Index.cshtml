<!-- Product Grid Section - Professional E-commerce Style -->
<div class="products-grid">
    @if (Model.ShowLoginWall)
    {
        @foreach (var product in Model.Products)
        {
            <div class="product-card">
                <div class="product-image">
                    @if (!string.IsNullOrEmpty(product.Image))
                    {
                        <img src="@Url.Content("~/images/" + product.Image)" alt="@product.Name">
                    }
                    else
                    {
                        <img src="@Url.Content("~/images/Next Horizon.jpg")" alt="@product.Name">
                    }

                    <div class="product-actions">
                        <button class="quick-view">
                            <i class="fas fa-eye"></i> Quick View
                        </button>
                    </div>
                </div>

                <div class="product-details">
                    <h3 class="product-title">@product.Name</h3>
                    <p class="product-description">@product.Description</p>
                    <div class="product-price">
                        <span class="price">$@product.Price</span>
                    </div>
                    <button class="add-to-cart">
                        <i class="fas fa-shopping-cart"></i> Add to Cart
                    </button>
                </div>
            </div>
        }

        @* Moved outside the loop to ensure it appears last *@
        <div class="login-wall-card">
            <div class="login-wall-content">
                <i class="fas fa-lock"></i>
                <h3>Login to See More</h3>
                <p>Access 30+ additional products and exclusive deals</p>
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary">
                    Login Now
                </a>
            </div>
        </div>
    }
</div>


<!-- Call to Action Section -->
<section class="cta-banner">
    <div class="container">
        <div class="cta-content">
            <h2>Ready to Join the Community?</h2>
            <p>Sign up today and start tracking your progress, competing with others, and achieving your fitness goals.</p>
            <div class="cta-buttons">
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">Get Started</a>
                <a asp-controller="Account" asp-action="BecomeSeller" class="btn btn-outline">Become a Seller</a>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const images = document.querySelectorAll('.shopee-carousel img');
        
        images.forEach((img, index) => {
            // Check if image is actually loaded with content
            if (img.complete && img.naturalWidth === 0) {
                console.error(`🚨 Image ${index + 1} (${img.src}) is BROKEN or EMPTY.`);
                img.style.border = "5px solid red"; // Visual cue
            } else {
                console.log(`✅ Image ${index + 1} loaded. Width: ${img.naturalWidth}px`);
            }

            // Listen for errors
            img.onerror = function() {
                console.error(`❌ Failed to load image: ${this.src}`);
                this.closest('.carousel-item').style.backgroundColor = "#ffcccc";
            };
        });
    });
</script>
