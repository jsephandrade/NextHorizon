@{
    ViewData["Title"] = "Terms of Service";
}

<!-- Terms Section -->
<section class="section" style="padding-top: 120px; min-height: 100vh;">
    <div class="contact-container" style="max-width: 900px;">
        <div class="section-header" style="margin-bottom: 3rem;">
            <h2 class="section-title">Terms of Service</h2>
            <p class="section-description">Last updated: January 2024</p>
        </div>
        
