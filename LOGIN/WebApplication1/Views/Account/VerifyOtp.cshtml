@model WebApplication1.ViewModels.VerifyOtpViewModel
@{
    ViewData["Title"] = "Verify OTP - Next Horizon";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-form-container">
            <div class="auth-header">
                <h2>Enter OTP</h2>
                <p>Check your email and enter the 6-digit OTP</p>
            </div>

            <form asp-action="VerifyOtp" method="post" class="auth-form">
                <!-- Hidden email to identify user -->
                <input type="hidden" asp-for="Email" />

                <div class="form-group">
                    <label for="Otp">OTP</label>
                    <input asp-for="Otp" class="form-input" placeholder="123456" />
                    <span asp-validation-for="Otp" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary auth-submit">
                    Verify OTP
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Auth Page Wrapper - Handles Centering */
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;    /* Vertical center */
        justify-content: center; /* Horizontal center */
        background: var(--color-off-white);
        padding: 1.5rem;
    }

    /* The Card Container */
    .auth-container {
        width: 100%;
        max-width: 450px; /* Adjust this to make the card wider or narrower */
        background: var(--color-white);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
    }

    .auth-form-container {
        padding: 3rem;
        display: flex;
        flex-direction: column;
    }

    /* Header Styles */
    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-header h2 {
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .auth-header p {
        color: var(--color-gray);
        font-size: 0.95rem;
    }

    /* Form Elements */
    .auth-form .form-group {
        margin-bottom: 1.5rem;
    }

    .auth-form label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .auth-submit {
        width: 100%;
        padding: 0.875rem;
        font-size: 1rem;
        background-color: var(--color-black);
        color: var(--color-white);
        border: none;
        border-radius: var(--border-radius-md);
        cursor: pointer;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .auth-submit:hover {
        opacity: 0.9;
    }

    /* Footer / Back Link */
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
    }

    .auth-footer a {
        color: var(--color-black);
        font-weight: 600;
        text-decoration: none;
        font-size: 0.875rem;
    }
</style>