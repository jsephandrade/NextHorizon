@model WebApplication1.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password - Next Horizon";
}

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-form-container">
            <div class="auth-header">
                <h2>Reset Password</h2>
                <p>Enter your new password and confirm it</p>
            </div>

            <form asp-action="ResetPassword" method="post" class="auth-form">
                <!-- Hidden email -->
                <input type="hidden" asp-for="Email" />
            

                <div class="form-group">
    <label asp-for="NewPassword"></label>
    <div class="password-wrapper">
        <input asp-for="NewPassword" class="form-input" id="newPass" placeholder="New password" />
        <button type="button" class="toggle-password" onclick="togglePassword('newPass', this)">
            <i class="fas fa-eye"></i>
        </button>
    </div>
    <span asp-validation-for="NewPassword" class="text-danger"></span>
</div>

<div class="form-group">
    <label asp-for="ConfirmPassword"></label>
    <div class="password-wrapper">
        <input asp-for="ConfirmPassword" class="form-input" id="confirmPass" placeholder="Confirm new password" />
        <button type="button" class="toggle-password" onclick="togglePassword('confirmPass', this)">
            <i class="fas fa-eye"></i>
        </button>
    </div>
    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
</div>
                <button type="submit" class="btn btn-primary auth-submit">
                    Reset Password
                </button>
            </form>
        </div>
    </div>
</div>

<style>
    /* Auth Page Wrapper - Handles Centering */
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;    /* Vertical center */
        justify-content: center; /* Horizontal center */
        background: var(--color-off-white);
        padding: 1.5rem;
    }

    /* The Card Container */
    .auth-container {
        width: 100%;
        max-width: 450px; /* Adjust this to make the card wider or narrower */
        background: var(--color-white);
        border-radius: var(--border-radius-lg);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
    }

    .auth-form-container {
        padding: 3rem;
        display: flex;
        flex-direction: column;
    }

    /* Header Styles */
    .auth-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .auth-header h2 {
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .auth-header p {
        color: var(--color-gray);
        font-size: 0.95rem;
    }

    /* Form Elements */
    .auth-form .form-group {
        margin-bottom: 1.5rem;
    }

    .auth-form label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .auth-submit {
        width: 100%;
        padding: 0.875rem;
        font-size: 1rem;
        background-color: var(--color-black);
        color: var(--color-white);
        border: none;
        border-radius: var(--border-radius-md);
        cursor: pointer;
        font-weight: 600;
        transition: opacity 0.2s;
    }

    .auth-submit:hover {
        opacity: 0.9;
    }

    /* Footer / Back Link */
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
    }

    .auth-footer a {
        color: var(--color-black);
        font-weight: 600;
        text-decoration: none;
        font-size: 0.875rem;
    }
    /* Position the wrapper relatively */
.password-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

/* Make the input take full width but add padding on the right for the icon */
.password-wrapper .form-input {
    width: 100%;
    padding-right: 45px; 
}

/* Style the eye button */
.toggle-password {
    position: absolute;
    right: 10px;
    background: none;
    border: none;
    color: var(--color-gray);
    cursor: pointer;
    padding: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
}

.toggle-password:hover {
    color: var(--color-black);
}
</style>

<script>
    function togglePassword(inputId, button) {
    const passwordInput = document.getElementById(inputId);
    const icon = button.querySelector('i');

    if (passwordInput.type === "password") {
        passwordInput.type = "text";
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
    } else {
        passwordInput.type = "password";
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
    }
}
</script>