<header id="main-header">
    <div class="header-inner">
        <div class="header-top">
            <button class="hdr-icon-btn sidebar-trigger-btn" id="mobile-sidebar-trigger"
                    onclick="openMobileSidebar()" aria-label="Open Menu">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <div class="logo">
                <a href="/"><img src="/images/new-logo.png" alt="NEXT HORIZON" class="header-logo-img"></a>
            </div>
            <div class="header-actions">
                <a href="/Home/Cart" class="hdr-icon-btn" aria-label="Shopping Cart">
                    <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                    </svg>
                </a>
                <div class="profile-dropdown-wrap" id="profile-wrap">
                    <button class="hdr-icon-btn" id="profile-btn" onclick="toggleProfileDropdown()"
                            aria-label="Account" aria-expanded="false">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                        </svg>
                    </button>
                    <div class="profile-dropdown" id="profile-dropdown">
                        <div class="profile-dd-user">
                            <div class="profile-dd-avatar"><i class="bi bi-person-circle"></i></div>
                            <div class="profile-dd-info">
                                <span class="profile-dd-name">My Account</span>
                                <span class="profile-dd-sub">Manage your profile</span>
                            </div>
                        </div>
                        <div class="profile-dd-divider"></div>
                        <a href="/Home/MyPurchases" class="profile-dropdown-item">
                            <i class="bi bi-bag-check"></i> My Purchases
                        </a>
                        <a href="#" class="profile-dropdown-item">
                            <i class="bi bi-person-gear"></i> Update Profile
                        </a>
                        <a href="#" class="profile-dropdown-item">
                            <i class="bi bi-geo-alt"></i> Shipping Address
                        </a>
                        <a href="#" class="profile-dropdown-item">
                            <i class="bi bi-credit-card"></i> Payment Methods
                        </a>
                        <div class="profile-dd-divider"></div>
                        <a href="/" class="profile-dropdown-item profile-dd-logout" onclick="logout()">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
