@{
}
<header id="main-header">
    <div class="header-inner">
        <div class="header-top">
            <div class="logo">
                <a href="/"><img src="/logo.png" alt="NEXT HORIZON" class="header-logo-img"></a>
            </div>

            <div class="header-actions">
                <a href="/Home/Cart" class="hdr-icon-btn" aria-label="Shopping Cart">
                    <span id="cart-count" class="hdr-badge">0</span>
                </a>
                <div class="profile-dropdown-wrap">
                    <button class="hdr-icon-btn" aria-label="Account">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    </button>
                    <div class="profile-dropdown">
                        <a asp-controller="AccountProfile" asp-action="ProfileView" class="profile-dropdown-item">View Profile</a>
                        <a href="/" class="profile-dropdown-item" onclick="logout()">Logout</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>
