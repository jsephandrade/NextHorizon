@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="profile-sidebar" id="sidebar">
    <nav class="sidebar-menu">
        <a href="/Home/Index" class="sidebar-link @(currentAction == "Index" ? "active" : "")">
            <i class="bi bi-house"></i> Home
        </a>
        <a href="/Home/MyPurchases" class="sidebar-link @(currentAction == "MyPurchases" ? "active" : "")">
            <i class="bi bi-bag-check"></i> My Purchases
        </a>
        <a href="/Home/MyOrders" class="sidebar-link @(currentAction == "MyOrders" ? "active" : "")">
            <i class="bi bi-clock-history"></i> Order History
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-person-gear"></i> Update Profile
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-geo-alt"></i> Shipping Address
        </a>
        <a href="#" class="sidebar-link">
            <i class="bi bi-credit-card"></i> Payment Methods
        </a>
    </nav>
</div>

<style>
    :root {
        --sidebar-width: 260px;
        --active-bg: #333333;
        --accent-line: #000000;
    }

    .profile-sidebar {
        width: var(--sidebar-width);
        height: 100%;
        background: #ffffff;
        border-right: 1px solid #d1d1d1;
        flex-shrink: 0;
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Poppins', sans-serif;
    }

    .sidebar-menu {
        display: flex;
        flex-direction: column;
        padding-top: 20px;
    }

    .sidebar-link {
        display: flex;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 16px 24px;
        text-decoration: none !important;
        color: #000;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        border-left: 4px solid transparent;
        box-sizing: border-box;
    }

    .sidebar-link i { font-size: 16px; opacity: 0.7; }

    .sidebar-link:hover,
    .sidebar-link.active {
        background-color: var(--active-bg);
        color: #fff !important;
        border-left: 4px solid var(--accent-line);
    }

    .sidebar-link:hover i,
    .sidebar-link.active i { opacity: 1; }

    @@media (max-width: 991px) {
        .profile-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 9999;
            transform: translateX(-100%);
            box-shadow: 10px 0 30px rgba(0,0,0,0.1);
        }
        .profile-sidebar.open {
            transform: translateX(0);
        }
    }
</style>
