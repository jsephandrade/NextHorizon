@model NextHorizon.ViewModels.DailyFitnessViewModel
@{
    ViewData["Title"] = "Daily Fitness Overview";
    var maxDistance = Model.HourlyData.Any() ? Model.HourlyData.Max(d => d.TotalDistance) : 1;
    var maxTime = Model.HourlyData.Any() ? Model.HourlyData.Max(d => d.TotalTimeSec) : 1;
    var maxSteps = Model.HourlyData.Any() ? Model.HourlyData.Max(d => d.TotalSteps) : 1;
}

<div class="centered-layout-container">
    <div class="fitness-content-wrapper">
        <div class="fitness-container">
            <div class="back-navigation">
                <a asp-controller="AccountProfile" asp-action="ProfileView"><i class="bi bi-chevron-left"></i> Back</a>
            </div>

            <div class="fitness-header">
                <h1>FITNESS OVERVIEW <span>(Today)</span></h1>
            </div>

            <div class="period-navbar">
                <a asp-controller="FitnessOverview" asp-action="DailyFitnessOverview" class="period-btn active">DAILY</a>
                <a asp-controller="FitnessOverview" asp-action="WeeklyFitnessOverview" class="period-btn">WEEKLY</a>
                <a asp-controller="FitnessOverview" asp-action="MonthlyFitnessOverview" class="period-btn">MONTHLY</a>
                <a asp-controller="FitnessOverview" asp-action="YearlyFitnessOverview" class="period-btn">YEARLY</a>
            </div>

            <div class="fitness-charts-grid">
                <!-- Distance Card -->
                <div class="chart-card">
                    <div class="chart-header">
                        <small>Total Distance</small>
                        <h3>@Model.FormattedTotalDistance</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            <span>@(Math.Ceiling(maxDistance * 0.75m))</span>
                            <span>@(Math.Ceiling(maxDistance * 0.5m))</span>
                            <span>@(Math.Ceiling(maxDistance * 0.25m))</span>
                            <span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container">
                                @foreach (var hour in new[] { 0, 6, 12, 18 })
                                {
                                    var data = Model.HourlyData.FirstOrDefault(d => d.HourOfDay == hour);
                                    var height = data != null && maxDistance > 0 
                                        ? (data.TotalDistance / maxDistance) * 100 
                                        : 0;
                                    var leftPosition = hour == 0 ? 25 : (hour == 6 ? 35 : (hour == 12 ? 75 : 85));
                                    <div class="bar" style="height: @(height)%; left: @(leftPosition)%;" 
                                         title="@hour:00 - @(data?.TotalDistance.ToString("0.0") ?? "0") KM"></div>
                                }
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>12 AM</span><span>6 AM</span><span>12 PM</span><span>6 PM</span>
                        </div>
                    </div>
                </div>

                <!-- Time Card -->
                <div class="chart-card">
                    <div class="chart-header">
                        <small>Total Time</small>
                        <h3>@Model.FormattedTotalTime</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            @{
                                var maxTimeHours = Math.Ceiling(maxTime / 3600m);
                            }
                            <span>@(maxTimeHours)</span>
                            <span>@(Math.Ceiling(maxTimeHours * 0.5m))</span>
                            <span>@(Math.Ceiling(maxTimeHours * 0.25m))</span>
                            <span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container">
                                @foreach (var hour in new[] { 0, 6, 12, 18 })
                                {
                                    var data = Model.HourlyData.FirstOrDefault(d => d.HourOfDay == hour);
                                    var height = data != null && maxTime > 0 
                                        ? ((decimal)data.TotalTimeSec / maxTime) * 100 
                                        : 0;
                                    var leftPosition = hour == 0 ? 45 : (hour == 6 ? 45 : (hour == 12 ? 45 : 45));
                                    <div class="bar" style="height: @(height)%; left: @(leftPosition)%;" 
                                         title="@hour:00 - @(data != null ? TimeSpan.FromSeconds(data.TotalTimeSec).ToString(@"hh\:mm") : "00:00")"></div>
                                }
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>12 AM</span><span>6 AM</span><span>12 PM</span><span>6 PM</span>
                        </div>
                    </div>
                </div>

                <!-- Steps Card -->
                <div class="chart-card">
                    <div class="chart-header">
                        <small>Count</small>
                        <h3>@Model.FormattedTotalSteps</h3>
                    </div>
                    <div class="chart-body">
                        <div class="chart-y-axis">
                            <span>@(Math.Ceiling(maxSteps * 0.75m).ToString("N0"))</span>
                            <span>@(Math.Ceiling(maxSteps * 0.5m).ToString("N0"))</span>
                            <span>@(Math.Ceiling(maxSteps * 0.25m).ToString("N0"))</span>
                            <span>0</span>
                        </div>
                        <div class="chart-placeholder">
                            <div class="mock-grid"></div>
                            <div class="bar-container">
                                @foreach (var hour in new[] { 0, 6, 12, 18 })
                                {
                                    var data = Model.HourlyData.FirstOrDefault(d => d.HourOfDay == hour);
                                    var height = data != null && maxSteps > 0 
                                        ? ((decimal)data.TotalSteps / maxSteps) * 100 
                                        : 0;
                                    var leftPosition = hour == 0 ? 25 : (hour == 6 ? 35 : (hour == 12 ? 75 : 75));
                                    <div class="bar" style="height: @(height)%; left: @(leftPosition)%;" 
                                         title="@hour:00 - @(data?.TotalSteps.ToString("N0") ?? "0") steps"></div>
                                }
                            </div>
                        </div>
                        <div class="chart-labels">
                            <span>12 AM</span><span>6 AM</span><span>12 PM</span><span>6 PM</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Your EXACT original styles - preserved completely -->
<style>
    /* Expanded Layout (Consistent across all 4 views) */
    .centered-layout-container {
        display: block;
        width: 100%;
        min-height: 100vh;
        background-color: #fff;
    }

    .fitness-content-wrapper {
        width: 100%;
        max-width: 100%; /* Expanded width */
        margin: 0;
        padding: 20px 60px 40px 60px; /* Unified horizontal padding */
    }

    .back-navigation a {
        text-decoration: none;
        color: #000;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .fitness-header h1 {
        font-size: 1.8rem;
        font-weight: 800;
        margin: 15px 0;
    }

        .fitness-header h1 span {
            font-weight: 400;
            font-size: 1.2rem;
            color: #444;
        }

    /* Period Navbar */
    .period-navbar {
        display: flex;
        background-color: #000;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 30px;
        width: 100%;
    }

    .period-btn {
        flex: 1;
        background: transparent;
        color: #fff;
        border: none;
        padding: 12px;
        font-weight: 700;
        text-transform: uppercase;
        text-align: center;
        text-decoration: none;
        cursor: pointer;
        border-right: 1px solid #444;
    }

        .period-btn.active {
            background-color: #777;
        }

    /* Charts Grid */
    .fitness-charts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        width: 100%;
    }

    .chart-card {
        background-color: #f0f0f0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .chart-header {
        background-color: #000;
        color: #fff;
        padding: 12px 15px;
    }

        .chart-header small {
            display: block;
            font-size: 0.75rem;
            opacity: 0.8;
        }

        .chart-header h3 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
        }

    .chart-body {
        padding: 15px;
        position: relative;
    }

    .chart-y-axis {
        position: absolute;
        right: 10px;
        top: 15px;
        height: 180px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        font-size: 0.65rem;
        color: #666;
    }

    .chart-placeholder {
        height: 180px;
        width: calc(100% - 35px);
        position: relative;
        border: 1px solid #000;
        background: #e8e8e8;
    }

    .mock-grid {
        height: 100%;
        width: 100%;
        background-image: linear-gradient(#ccc 1px, transparent 1px), linear-gradient(90deg, #ccc 1px, transparent 1px);
        background-size: 33.33% 33.33%;
    }

    .bar-container {
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 100%;
    }

    .bar {
        position: absolute;
        bottom: 0;
        width: 15px;
        background-color: #000;
    }

    .chart-labels {
        display: flex;
        justify-content: space-between;
        padding-right: 35px;
        margin-top: 5px;
        font-size: 0.65rem;
        color: #666;
    }

    /* Responsive scaling */
    @@media (max-width: 1200px) {
        .fitness-charts-grid {
            grid-template-columns: 1fr;
        }

        .fitness-content-wrapper {
            padding: 20px 20px;
        }
    }
</style>