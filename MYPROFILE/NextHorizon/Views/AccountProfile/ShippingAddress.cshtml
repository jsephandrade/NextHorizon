@model NextHorizon.ViewModels.ShippingAddressViewModel
@{
    ViewData["Title"] = "Shipping Address";
    Layout = "_ProfileLayout";
}

<div class="profile-layout-container">
    <main class="main-content-wrapper">
        <div class="address-container-centered">
            <div class="header-with-action">
                <h2 class="page-title">Shipping Address</h2>
                <button class="btn-add-new" id="showFormBtn" style="@(Model.ExistingAddresses.Any() ? "" : "display: none;")">
                    <i class="bi bi-plus-lg"></i> ADD NEW ADDRESS
                </button>
            </div>

            <hr class="section-divider">

            <div id="addressList" class="address-list-grid">
                @if (Model.ExistingAddresses.Any())
                {
                    @foreach (var address in Model.ExistingAddresses)
                    {
                        <div class="saved-address-card @(address.IsDefault ? "default-card" : "")" 
                             data-id="@address.ShippingAddressId"
                             data-region="@address.Region"
                             data-province="@address.Province"
                             data-city="@address.CityMunicipality"
                             data-barangay="@address.Barangay"
                             data-house="@address.HouseNumber"
                             data-building="@address.Building"
                             data-street="@address.StreetName"
                             data-postal="@address.PostalCode"
                             data-isdefault="@address.IsDefault.ToString().ToLower()">
                            
                            @if (address.IsDefault)
                            {
                                <div class="default-badge">DEFAULT</div>
                            }
                            
                            <div class="address-details">
                                <p class="street-line">
                                    <strong>
                                        @address.HouseNumber@if (!string.IsNullOrEmpty(address.Building))
                                        {<text>, @address.Building</text>}, @address.StreetName
                                    </strong>
                                </p>
                                <p class="area-line">
                                    @address.Barangay, @address.CityMunicipality, @address.Province, @address.Region @address.PostalCode
                                </p>
                            </div>
                            
                            <div class="address-controls">
                                <button class="control-btn edit-btn" title="Edit" data-id="@address.ShippingAddressId">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="control-btn delete-btn" title="Delete" data-id="@address.ShippingAddressId">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>

            <div id="emptyState" class="empty-address-view" style="@(Model.ExistingAddresses.Any() ? "display: none;" : "")">
                <div class="empty-icon-wrapper">
                    <i class="bi bi-geo-alt"></i>
                </div>
                <p class="empty-text">No shipping addresses saved yet.</p>
                <p class="empty-subtext">Save your address for a faster checkout experience.</p>
                <button class="btn-submit-black" id="emptyAddBtn" style="margin-top: 20px; width: auto; padding: 15px 40px;">
                    + ADD SHIPPING ADDRESS
                </button>
            </div>

            <div id="newAddressForm" class="address-form-card" style="display: none;">
                <div class="form-header">
                    <button id="cancelBtn" class="back-link">
                        <i class="bi bi-chevron-left"></i> BACK TO SAVED ADDRESSES
                    </button>
                </div>

                <div class="form-body">
                    <h3 class="form-section-title">SHIPPING DETAILS</h3>

                    <form id="shippingAddressForm" asp-action="SaveShippingAddress" method="post">
                        <input type="hidden" id="addressId" name="ShippingAddressId" />
                        <input type="hidden" asp-for="UserId" />
                        @Html.AntiForgeryToken()
                        <div class="form-grid">
                            <div class="input-field">
                                <label>REGION</label>
                                <input type="text" id="regionInput" name="Region" list="regionList" class="custom-input" placeholder="Select Region" required>
                                <datalist id="regionList"></datalist>
                            </div>

                            <div class="input-field">
                                <label>POSTAL CODE</label>
                                <input type="text" id="postalInput" name="PostalCode" class="custom-input" placeholder="0000" required>
                            </div>

                            <div class="input-field">
                                <label>PROVINCE</label>
                                <input type="text" id="provinceInput" name="Province" list="provinceList" class="custom-input" placeholder="Select Province" required>
                                <datalist id="provinceList"></datalist>
                            </div>

                            <div class="input-field">
                                <label>CITY / MUNICIPALITY</label>
                                <input type="text" id="cityInput" name="CityMunicipality" list="cityList" class="custom-input" placeholder="Select City" required>
                                <datalist id="cityList"></datalist>
                            </div>

                            <div class="input-field full-row">
                                <label>BARANGAY</label>
                                <input type="text" id="barangayInput" name="Barangay" list="barangayList" class="custom-input" placeholder="Select Barangay" required>
                                <datalist id="barangayList"></datalist>
                            </div>

                            <div class="input-field">
                                <label>HOUSE NO. / UNIT / FLOOR</label>
                                <input type="text" id="houseInput" name="HouseNumber" class="custom-input" placeholder="e.g. House 123" required>
                            </div>

                            <div class="input-field">
                                <label>BUILDING (OPTIONAL)</label>
                                <input type="text" id="buildingInput" name="Building" class="custom-input" placeholder="e.g. Grand Tower">
                            </div>

                            <div class="input-field full-row">
                                <label>STREET NAME</label>
                                <input type="text" id="streetNameInput" name="StreetName" class="custom-input" placeholder="e.g. Maple Street" required>
                            </div>
                        </div>

                        <div class="toggle-container">
                            <span class="toggle-label">Set as Default Address</span>
                            <label class="ios-switch">
                                <input type="checkbox" id="defaultToggle" name="IsDefault">
                                <span class="slider"></span>
                            </label>
                        </div>

                        <div class="form-buttons">
                            <button type="submit" class="btn-pill btn-black" id="saveBtn">SAVE ADDRESS</button>
                            <button type="button" class="btn-pill btn-gray" id="formCancelBtn">CANCEL</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/shippingAddress.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/shippingAddress.js" asp-append-version="true"></script>
    
    <script>
        // Pass server-side data to JavaScript
        window.initialAddresses = @Html.Raw(Json.Serialize(Model.ExistingAddresses));
    </script>
}