@model NextHorizon.ViewModels.UpdateProfileViewModel
@{
    ViewData["Title"] = "Account Details";
    Layout = "_ProfileLayout";
}

<div class="main-content-wrapper">
    <div class="content-body update-profile-body">
        <div class="account-details-full-width">
            <div class="header-with-action">
                <h2 class="page-title">Account Details</h2>
            </div>

            <!-- Personal Information -->
            <div class="info-group-card">
                <div class="info-row" id="name-row" data-field="fullname">
                    <span class="info-label">Full Name</span>
                    <span class="info-value @(string.IsNullOrEmpty(Model.FullName) ? "text-muted" : "")">
                        @(Model.FullName ?? "Set now") <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
                <div class="info-row" id="username-row" data-field="username">
                    <span class="info-label">Username</span>
                    <span class="info-value @(string.IsNullOrEmpty(Model.Username) ? "text-muted" : "")">
                        @(Model.Username ?? "Set now") <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="info-group-card">
                <div class="info-row" id="address-row" data-field="address">
                    <span class="info-label">Address</span>
                    <span class="info-value @(string.IsNullOrEmpty(Model.Address) ? "text-muted" : "")">
                        @(Model.Address ?? "Set now") <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
                <div class="info-row" id="phone-row" data-field="phone">
                    <span class="info-label">Phone Number</span>
                    <span class="info-value @(string.IsNullOrEmpty(Model.PhoneNumber) ? "text-muted" : "")">
                        @(Model.PhoneNumber ?? "Set now") <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
            </div>

            <!-- Account Information -->
            <div class="info-group-card">
                <div class="info-row" id="email-row" data-field="email">
                    <span class="info-label">Email</span>
                    <span class="info-value @(string.IsNullOrEmpty(Model.Email) ? "text-muted" : "")">
                        @(Model.Email ?? "Set now") <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
                <div class="info-row" id="password-row">
                    <span class="info-label">Password</span>
                    <span class="info-value">
                        Update <i class="bi bi-chevron-right"></i>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Full Name Modal -->
<div id="fullnameModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-header">
            <span>EDIT FULL NAME</span>
            <button class="close-btn" onclick="closeModal('fullnameModal')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body">
            <label class="input-sublabel">First Name</label>
            <input type="text" id="firstNameInput" class="modal-input" placeholder="First name" value="@Model.FirstName" />
            
            <label class="input-sublabel">Middle Name (Optional)</label>
            <input type="text" id="middleNameInput" class="modal-input" placeholder="Middle name" value="@Model.MiddleName" />
            
            <label class="input-sublabel">Last Name</label>
            <input type="text" id="lastNameInput" class="modal-input" placeholder="Last name" value="@Model.LastName" />
            
            <button class="save-btn" onclick="saveFullName()">SAVE</button>
        </div>
    </div>
</div>

<!-- Universal Modal for single field input -->
<div id="universalModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-header">
            <span id="modalTitle">EDIT</span>
            <button class="close-btn" onclick="closeModal('universalModal')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body">
            <input type="text" id="modalInput" class="modal-input" placeholder="Enter value..." />
            <button class="save-btn" onclick="saveField()">SAVE</button>
        </div>
    </div>
</div>

<!-- Password Modal -->
<div id="passwordModal" class="modal-overlay">
    <div class="modal-card">
        <div class="modal-header">
            <span>CHANGE PASSWORD</span>
            <button class="close-btn" onclick="closeModal('passwordModal')"><i class="bi bi-x"></i></button>
        </div>
        <div class="modal-body" style="padding-top: 10px; text-align: left;">
            <label class="input-sublabel">Current Password</label>
            <input type="password" id="currentPassword" class="modal-input" placeholder="••••••••" />

            <label class="input-sublabel">New Password</label>
            <input type="password" id="newPassword" class="modal-input" placeholder="••••••••" />

            <label class="input-sublabel">Confirm New Password</label>
            <input type="password" id="confirmPassword" class="modal-input" placeholder="••••••••" />

            <button class="save-btn" onclick="savePassword()">SAVE</button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Styles {
    <link rel="stylesheet" href="~/css/UpdateProfile.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/UpdateProfile.js" asp-append-version="true"></script>
}